# ───────────────────────────────────────────────
# Hostaffin sGTM Platform — environment template
# Copy to `.env` and fill in real values.
# ───────────────────────────────────────────────

# App
APP_ENV=development
APP_NAME=hostaffin-sgtm
HTTP_PORT=8080
LOG_LEVEL=debug
BASE_URL=http://localhost:8080

# Postgres
DATABASE_URL=postgres://sgtm:sgtm@localhost:5432/sgtm?sslmode=disable
DB_MAX_OPEN=25
DB_MAX_IDLE=5

# Redis
REDIS_URL=redis://localhost:6379/0

# ClickHouse
CLICKHOUSE_URL=clickhouse://localhost:9000
CLICKHOUSE_DB=sgtm

# JWT (generate with `make keys`)
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Node Agent shared secret (HMAC for webhooks)
NODE_AGENT_SHARED_SECRET=change-me-please

# WHMCS
WHMCS_BASE_URL=https://billing.example.com
WHMCS_API_IDENTIFIER=
WHMCS_API_SECRET=
WHMCS_WEBHOOK_SECRET=change-me-please

# Traefik
TRAEFIK_API_URL=http://localhost:8081
EDGE_DOMAIN=edge.hostaffin.local

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hostaffin <noreply@hostaffin.com>"

# Alerting
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Local dev convenience
ADMIN_BOOTSTRAP_EMAIL=admin@hostaffin.local
ADMIN_BOOTSTRAP_PASSWORD=ChangeMe!123